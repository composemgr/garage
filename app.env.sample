# Garage S3-compatible object storage environment configuration
# Copy to app.env and customize before starting

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=garage.example.com
BASE_DOMAIN_NAME=example.com

# S3 credentials for the web manager UI
S3_ACCESS_KEY=changeme_s3_access_key
S3_SECRET_KEY=changeme_s3_secret_key

# Garage admin/metrics tokens (min 32 chars each)
DB_ADMIN_PASS=changeme_admin_password
APP_API_TOKEN=changeme_metrics_token_min_32_chars

# RPC secret shared between Garage nodes (min 64 hex chars)
RPC_SECRET=changeme_rpc_secret_min_64_chars
